# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/floww"

# Server
PORT=8100
NODE_ENV=development

# Security
JWT_SECRET="your-secret-key-change-in-production"
JWT_ACCESS_EXPIRY="30m"
JWT_REFRESH_EXPIRY="7d"

# CORS
CORS_ORIGINS="http://localhost:4000,http://127.0.0.1:4000"

# Storage
STORAGE_PATH="./storage"
ARCHIVE_PATH="./archive_storage"
GRAPH_PATH="./graph_storage"
SCREENSHOT_PATH="./storage/screenshots"
OUTPUT_PATH="./storage/output"

# Auth
DISABLE_AUTH=true  # Set to false in production

# LLM (Optional - for AI-powered documentation)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
LLM_PROVIDER="openai"  # openai or anthropic

# Redis (Optional - for background workers)
REDIS_URL=""  # e.g., redis://localhost:6382
