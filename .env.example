# Floww Configuration
# Copy this file to .env and fill in your values

# Database
FLOWW_DATABASE_URL=sqlite:///floww.db
FLOWW_STORAGE_PATH=./storage

# LLM Provider API Keys (at least one required)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_API_KEY=your-google-api-key

# Default LLM Provider (openai, anthropic, google)
FLOWW_LLM_PROVIDER=openai

# Optional: Redis for task queue
# FLOWW_REDIS_URL=redis://localhost:6379

# Logging
FLOWW_LOG_LEVEL=INFO

# Security (for production)
# FLOWW_SECRET_KEY=your-secret-key-here
# FLOWW_ENCRYPTION_KEY=your-encryption-key-here
 